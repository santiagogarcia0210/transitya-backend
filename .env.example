# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_SA=                    # JSON de service account (minificado, sin saltos de línea)
FIREBASE_STORAGE_BUCKET=        # ej: gestion-transporte-ef756.appspot.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=                   # separar por comas: https://app.transitya.com,https://www.transitya.com

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=                # token de acceso de Mercado Pago

# ── Frontend URL (para back_urls de MP) ───────────────────────────────────────
FRONTEND_URL=                   # ej: https://app.transitya.com

# ── Mailer ────────────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=

# ── Anthropic (módulo IA) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── ARCA / AfipSDK ────────────────────────────────────────────────────────────
AFIPSDK_ACCESS_TOKEN=           # token de la plataforma AfipSDK (app.afipsdk.com → tu cuenta)
ENCRYPTION_KEY=                 # exactamente 32 bytes UTF-8 para AES-256-GCM (sin espacios extra)
